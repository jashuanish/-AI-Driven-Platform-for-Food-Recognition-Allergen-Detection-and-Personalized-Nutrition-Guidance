# OPENROUTER_API_KEY: Required for OpenRouter AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ── AddiSafe gateway proxy (server.js) ─────────────────────────────
# Port the Express gateway listens on. GATEWAY_PORT takes priority over
# PORT (PORT is often injected by dev runners / cloud platforms).
GATEWAY_PORT=8787

# Redis connection. If unreachable the gateway silently falls back to an
# in-memory TTL cache, so Redis is optional for local development.
REDIS_URL=redis://localhost:6379

# Cache TTLs (seconds)
CACHE_TTL_PUBCHEM=86400
CACHE_TTL_OPENFDA=3600

# Rate limiting for /api routes
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Outbound request timeout (ms)
UPSTREAM_TIMEOUT_MS=10000
